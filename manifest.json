{
  "manifest_version": 3,
  "name": "ZenLoadBar",
  "version": "1.0",

  "developer": {
    "name": "vimlinuz",
    "url": "https://vimlinuz.is-a.dev/"
  },

  "homepage_url": "https://www.github.com/vimlinuz/ZenLoadBar",
  "description": "loading animation in the center of screen",

  "icons": {
    "48": "icons/ZenLoadBar.png",
    "96": "icons/ZenLoadBar.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "ZenLoadBar@vimlinuz",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["./src/main.js"]
    }
  ],

  "background": {
    "scripts": ["./src/background.js"]
  },

  "permissions": ["tabs"]
}
